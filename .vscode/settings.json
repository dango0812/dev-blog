{
  "search.exclude": {
    "**/node_modules": true
  },
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,

  "eslint.useFlatConfig": true,
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],

  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,

  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js, ${capture}.test.ts, ${capture}.test.tsx",
    "*.tsx": "${capture}.ts, ${capture}.test.ts, ${capture}.test.tsx",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "pnpm-lock.yaml",
    "eslint.config.js": "prettier.config.js, .prettierignore",
    "next.config.ts": ".mcp.json, next-env.d.ts",
    "components.json": "components.json, postcss.config.mjs"
  }
}
